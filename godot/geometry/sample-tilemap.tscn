; A painted TileMapLayer. The exporter flattens `tile_map_data` to per-cell
; sprite placements (frame = "<sheet>_<row*cols+col>#0"), so the runtime just
; stamps one Sprite per cell — no atlas-slicing at runtime. Repaint in Godot to
; change it; the base64 below is a 6×3 block (surface row of tile 3, fill of tile 2).
[node name="ground" type="TileMapLayer" parent="."]
tile_map_data = PackedByteArray("AAAAAAAAAQADAAAAAAAAAAEAAQACAAAAAAAAAAIAAQACAAAAAAABAAAAAQADAAAAAAABAAEAAQACAAAAAAABAAIAAQACAAAAAAACAAAAAQADAAAAAAACAAEAAQACAAAAAAACAAIAAQACAAAAAAADAAAAAQADAAAAAAADAAEAAQACAAAAAAADAAIAAQACAAAAAAAEAAAAAQADAAAAAAAEAAEAAQACAAAAAAAEAAIAAQACAAAAAAAFAAAAAQADAAAAAAAFAAEAAQACAAAAAAAFAAIAAQACAAAAAAA=")
tile_set = SubResource("TileSet_1")
