; Box2DCurve: the bezier outline is tessellated (curve_samples per segment) and
; rendered with a masked tiled fill + tiled border, just like Box2DPolygon. No
; corner texture here — a smooth curve has only shallow turns, so corner pieces
; would be suppressed by border_corner_min_angle anyway.
[node name="curve-blob" type="Path2D" parent="."]
script = ExtResource("2_curve")
texture = ExtResource("3_fill")
curve = SubResource("Curve2D_1")
curve_samples = 12
tile_fill = true
border_texture = ExtResource("4_border")
border_width = 12.0
border_texture_scale = 0.5
border_closed = true
