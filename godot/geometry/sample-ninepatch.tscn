[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://box2d/box2d_root.gd" id="1_root"]
[ext_resource type="Script" path="res://box2d/box2d_nine_slice.gd" id="2_nine"]
[ext_resource type="Texture2D" path="res://sprites/bg/bg.tres" id="3_bg"]

[node name="Geometry" type="Node2D"]
script = ExtResource("1_root")
gravity = Vector2(0, -10)

; A Box2DNineSlice (a Sprite2D with the nine-slice script). Assign a texture
; whose aseprite source had a `-slices` layer — the non-stretching borders
; (here 15/16/16/16) are baked into the atlas metadata and threaded through to
; the runtime NineSliceSprite, so you only set `size` (the stretched target).
; Corners stay fixed; edges + center stretch to fill the 192×128 box.
[node name="panel" type="Sprite2D" parent="."]
texture = ExtResource("3_bg")
script = ExtResource("2_nine")
size = Vector2(192, 128)
